---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Stellaris 背景设定知识库' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Stellaris 知识库</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href={`${base}/styles/global.css`} />
  </head>
  <body>
    <canvas id="starfield"></canvas>

    <nav class="main-nav">
      <div class="nav-brand">
        <a href={`${base}/`}>Stellaris KB</a>
      </div>
      <div class="nav-links">
        <a href={`${base}/`}>首页</a>
        <a href={`${base}/wiki/empires`}>百科</a>
        <a href={`${base}/graph`}>图谱</a>
        <a href={`${base}/timeline`}>时间线</a>
        <a href={`${base}/api`}>API</a>
        <button id="search-toggle" class="search-toggle">⌕ 搜索</button>
      </div>
    </nav>

    <div id="search-overlay" class="search-overlay" style="display:none">
      <div class="search-box">
        <div id="pagefind-search"></div>
        <button id="search-close" class="search-close">✕</button>
      </div>
    </div>

    <main class="page-content">
      <slot />
    </main>

    <footer class="site-footer">
      <p>STELLARIS KNOWLEDGE BASE v1.0 // ASTRO + YAML // <a href="https://github.com/GoDiao/stellaris-knowledge-base">GITHUB</a></p>
    </footer>

    <style>
      .search-toggle {
        background: none;
        border: 1px solid var(--hud-border);
        color: var(--text-secondary);
        font-family: var(--font-body);
        font-size: 0.75rem;
        padding: 0.3rem 0.7rem;
        border-radius: 3px;
        cursor: pointer;
        transition: all 0.25s ease;
        letter-spacing: 0.05em;
      }
      .search-toggle:hover {
        color: var(--text-glow);
        border-color: var(--text-glow);
        background: rgba(0, 229, 160, 0.06);
      }
      .search-overlay {
        position: fixed;
        inset: 0;
        z-index: 500;
        background: rgba(3, 3, 5, 0.9);
        backdrop-filter: blur(8px);
        display: flex;
        align-items: flex-start;
        justify-content: center;
        padding-top: 15vh;
      }
      .search-box {
        width: min(640px, 90vw);
        background: var(--panel);
        border: 1px solid var(--hud-border);
        padding: 1.5rem;
        position: relative;
        border-radius: 2px;
      }
      .search-close {
        position: absolute;
        top: 1rem;
        right: 1rem;
        background: none;
        border: none;
        color: var(--text-dim);
        font-size: 1.2rem;
        cursor: pointer;
      }
      .search-close:hover { color: var(--text-glow); }
      /* Pagefind overrides */
      .pagefind-ui__search-input {
        background: var(--void-light) !important;
        border: 1px solid var(--hud-border) !important;
        color: var(--text-primary) !important;
        font-family: var(--font-body) !important;
        border-radius: 2px !important;
      }
      .pagefind-ui__search-input::placeholder { color: var(--text-dim) !important; }
      .pagefind-ui__result-link { color: var(--text-glow) !important; font-family: var(--font-display) !important; }
      .pagefind-ui__result-excerpt { color: var(--text-secondary) !important; font-family: var(--font-body) !important; }
      .pagefind-ui__result-nested { border-color: var(--hud-border) !important; }
      .pagefind-ui__filter-name, .pagefind-ui__filter-group { color: var(--text-secondary) !important; }
      .pagefind-ui mark { color: var(--text-glow) !important; background: rgba(0,229,160,0.15) !important; }
    </style>

    <script is:inline>
      // Search overlay logic - is:inline prevents Vite from processing imports
      var _pfLoaded = false;
      document.getElementById('search-toggle')?.addEventListener('click', function() {
        var overlay = document.getElementById('search-overlay');
        overlay.style.display = 'flex';
        if (!_pfLoaded) {
          var s = document.createElement('script');
          s.src = '/pagefind/pagefind.js';
          s.onload = function() {
            PagefindUI({ element: '#pagefind-search', showSubResults: true });
            _pfLoaded = true;
            setTimeout(function() {
              var input = document.querySelector('.pagefind-ui__search-input');
              if (input) input.focus();
            }, 100);
          };
          document.head.appendChild(s);
        }
      });
      document.getElementById('search-close')?.addEventListener('click', function() {
        document.getElementById('search-overlay').style.display = 'none';
      });
      document.getElementById('search-overlay')?.addEventListener('click', function(e) {
        if (e.target === this) this.style.display = 'none';
      });
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') document.getElementById('search-overlay').style.display = 'none';
      });
    </script>

    <script>
      (function() {
        const canvas = document.getElementById('starfield');
        if (!canvas) return;
        const ctx = canvas.getContext('2d');
        let stars = [];
        const STAR_COUNT = 200;

        function resize() {
          canvas.width = window.innerWidth;
          canvas.height = window.innerHeight;
        }
        resize();
        window.addEventListener('resize', resize);

        for (let i = 0; i < STAR_COUNT; i++) {
          stars.push({
            x: Math.random() * canvas.width,
            y: Math.random() * canvas.height,
            size: Math.random() * 1.5 + 0.3,
            opacity: Math.random(),
            speed: Math.random() * 0.3 + 0.05,
            twinkleSpeed: Math.random() * 0.02 + 0.005,
            twinklePhase: Math.random() * Math.PI * 2
          });
        }

        let time = 0;
        function draw() {
          time += 1;
          ctx.clearRect(0, 0, canvas.width, canvas.height);

          // Draw nebula-like background gradient
          const gradient = ctx.createRadialGradient(
            canvas.width * 0.3, canvas.height * 0.4, 0,
            canvas.width * 0.3, canvas.height * 0.4, canvas.width * 0.6
          );
          gradient.addColorStop(0, 'rgba(20, 15, 40, 0.3)');
          gradient.addColorStop(0.5, 'rgba(5, 5, 15, 0.1)');
          gradient.addColorStop(1, 'transparent');
          ctx.fillStyle = gradient;
          ctx.fillRect(0, 0, canvas.width, canvas.height);

          // Draw stars
          for (const star of stars) {
            star.twinklePhase += star.twinkleSpeed;
            const twinkle = Math.sin(star.twinklePhase) * 0.4 + 0.6;
            const currentOpacity = star.opacity * twinkle;

            ctx.beginPath();
            ctx.arc(star.x, star.y, star.size, 0, Math.PI * 2);
            ctx.fillStyle = `rgba(220, 225, 240, ${currentOpacity})`;
            ctx.fill();

            // Slight parallax drift
            star.y += star.speed;
            if (star.y > canvas.height) {
              star.y = 0;
              star.x = Math.random() * canvas.width;
            }
          }

          requestAnimationFrame(draw);
        }
        draw();
      })();
    </script>
  </body>
</html>
